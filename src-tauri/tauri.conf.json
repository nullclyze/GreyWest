{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "greywest",
  "version": "1.0.0",
  "identifier": "com.nullclyze.greywest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GreyWest",
        "width": 1100,
        "height": 560,
        "resizable": false,
        "devtools": true,
        "center": true,
        "fullscreen": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
